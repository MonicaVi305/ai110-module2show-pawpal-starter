classDiagram
    class Owner <<dataclass>> {
        +String name
        +List~String~ preferences
        +List~Pet~ pets
    }

    class Pet <<dataclass>> {
        +String name
        +String species
        +List~String~ careNeeds
    }

    class Task <<dataclass>> {
        +String title
        +int durationMinutes
        +String priority
        +String category
    }

    class Scheduler {
        +buildPlan(owner: Owner, pet: Pet) List~Task~
        +explainPlan(tasks: List~Task~) String
    }

    Owner "1" --> "1..*" Pet : owns
    Pet "1" --> "0..*" Task : includes
    Scheduler --> Owner : uses
    Scheduler --> Pet : uses